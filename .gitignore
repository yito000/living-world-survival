# --- 環境変数（実値） ---
.env
# RC プロファイルの実値（10B 3.8）。テンプレートの .env.rc.example のみコミットする。
.env.rc
*.env.local

# --- Go ---
coverage.out
coverage.html
*.test
# Go build cache is kept in ~/.cache (03B 5.5)
# コンパイル済みバイナリ（`go build` の成果物）はコミットしない。
/services/api/apid
/services/auth/authd
/services/tools/loadgen/loadgen
/services/tools/recoverygen/recoverygen

# --- Python ---
__pycache__/
*.py[cod]
.venv/
venv/
.mypy_cache/
.ruff_cache/
.pytest_cache/
*.egg-info/
.uv/

# --- proto 生成物のうち Go/Python 側 ---
# 生成コードはコミットしてドリフト検査する方針のため無視しない。
# （unity/SurvivalWorld/Assets/Generated も同様にコミット対象）

# --- Blender / assets ---
build/
*.blend1

# --- Docker / infra ---
# pgdata は named volume のため対象外

# --- OS / editor ---
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# --- 一時 PowerShell 検証ファイル（ルート直下の暫定物） ---
/test.ps1
/test2.ps1

# --- Visual Studio / Unity generated workspace files ---
.vs/
*.slnx
# --- Unity M7 generated import outputs ---
# Regenerated by scripts/unity_import_assets.ps1 from build/assets/manifest.json.
unity/SurvivalWorld/Assets/Generated/ImportedModels/
unity/SurvivalWorld/Assets/Generated/Prefabs/
unity/SurvivalWorld/Assets/Generated/ImportedModels.meta
unity/SurvivalWorld/Assets/Generated/Prefabs.meta
