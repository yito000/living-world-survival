# Release Candidate 用環境変数テンプレート（10B 3.8）。
# 実値は .env.rc（gitignore）にコピーして使う: cp .env.rc.example .env.rc
#   docker compose -f infra/docker-compose.yml -f infra/docker-compose.rc.yml up -d
#
# dev の .env.example とは別ファイルにしてある（sslmode をローカルと RC で
# 混同しないため, 3.4 / 落とし穴）。ローカルは disable、RC は require。
#
# MVP-SEC-007: 実 secret は Repo に保存しない。以下の CHANGE_ME_ は必ず
# 環境変数 / Docker secret / CI の secret store から注入して置き換える。
# 置換し忘れると scripts/security_scan.sh と各サービスの起動時検証で落ちる。

# --- Database (PostgreSQL) ---
# RC は TLS 必須（3.4 / 落とし穴「sslmode をローカルと RC で混同しない」）。
# disable に戻すと security_scan が RC プロファイルで失敗する。
DATABASE_URL=postgres://survival:CHANGE_ME_DB_PASSWORD@postgres:5432/survival?sslmode=require
# migrate.sh などホストから直接叩く場合に使う（scripts/migrate.sh が参照）。
DATABASE_URL_HOST=postgres://survival:CHANGE_ME_DB_PASSWORD@localhost:5432/survival?sslmode=require

POSTGRES_USER=survival
# dev の survival/survival を RC へ持ち込まない。注入必須。
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
POSTGRES_DB=survival

# --- NATS JetStream ---
# RC は internal ネットワークのみ（MVP-SEC-001）。ホストへは publish しない。
NATS_URL=nats://nats:4222

# --- サービスポート ---
# RC で外部へ publish するのは auth の 8081 だけ（MVP-SEC-001）。
# 残りは internal ネットワーク内の待受ポート。
AUTH_PORT=8081
API_PORT=8082
WORLDSTATE_PORT=8083
LLM_WORKER_PORT=8084

# --- 認証 ---
# RC 用に新規生成すること。dev の決め打ち鍵は絶対に流用しない。
#   例: openssl rand -base64 48
JWT_SIGNING_KEY=CHANGE_ME_JWT_SIGNING_KEY

# --- M1 Auth / Matchmaking ---
# Access Token = 短寿命 JWT（HS256, 上の JWT_SIGNING_KEY で署名）。
ACCESS_TOKEN_TTL=15m
# Refresh Token = 不透明ランダム（DB はハッシュ保存）。ローテーション寿命。
REFRESH_TOKEN_TTL=720h
# Join Ticket 署名（Ed25519 / EdDSA JWS）。RC 用の鍵ペアを新規生成すること。
#   SIGNING_KEY = base64(std) の 32byte seed、PUBLIC_KEY = base64(std) の 32byte 公開鍵。
#   DS(Windows/04A) へ配布するのは PUBLIC_KEY のみ。SIGNING_KEY は Auth だけが持つ。
JOIN_TICKET_SIGNING_KEY=CHANGE_ME_JOIN_TICKET_SIGNING_KEY
JOIN_TICKET_PUBLIC_KEY=CHANGE_ME_JOIN_TICKET_PUBLIC_KEY
JOIN_TICKET_TTL=60s
# 内部 gRPC MatchmakingService の待受ポート（DS⇔Auth 専用, internal のみ）。
AUTH_GRPC_PORT=9091
# 内部 gRPC の共有シークレット。dev では空=無効だが RC は必須（MVP-SEC-007）。
# 空のままだと x-service-secret 検証が無効になり、internal 網に入れた相手を
# 誰でも Matchmaking gRPC に通してしまう。
AUTH_GRPC_SHARED_SECRET=CHANGE_ME_AUTH_GRPC_SHARED_SECRET

# --- M7 Rate Limit（第16章 Auth 失敗の Rate Limit / MVP-SEC-005, 10B 3.4） ---
# ログインは **失敗のみ** を数える（成功はトークンを消費しないので、正規利用者は
# 何度ログインしても遮断されない）。キーは送信元 IP。
LOGIN_RATE_LIMIT=10
LOGIN_RATE_WINDOW=1m
# 瞬間的に許す最大数（未指定なら LOGIN_RATE_LIMIT と同じ）。
LOGIN_RATE_BURST=10
# アカウント作成は試行そのものを数える（総当り登録の抑止）。
ACCOUNT_CREATE_RATE_LIMIT=5
ACCOUNT_CREATE_RATE_WINDOW=1m

# --- M2 API（WorldData / ActorState 永続化 gRPC） ---
# HTTP(health) は API_PORT=8082、gRPC は別ポート（DS が接続する先, 落とし穴6.10）。
# RC ではどちらも internal 限定（MVP-SEC-001）。
API_GRPC_PORT=8092
# 内部 gRPC の共有シークレット。dev では空=無効だが RC は必須（MVP-SEC-007）。
API_GRPC_SHARED_SECRET=CHANGE_ME_API_GRPC_SHARED_SECRET
# Item Definition マスタ（正本 JSON）のパス。コンテナ内は /data 配下。
ITEM_DEFINITIONS_PATH=data/item_definitions.json
# Outbox relay のポーリング間隔（≤1s, 3.6）。
OUTBOX_RELAY_INTERVAL=1s

# --- M6 Economy（EconomyService / 資産ランキング Batch） ---
# 資産ランキング Batch の実行間隔（既定 1時間・MVP 12.3 / 09B 3.9）。
# 手動実行は内部 HTTP: POST http://api:8082/admin/ranking/run（MVP-SEC-001 内部限定）。
RANKING_BATCH_INTERVAL=1h

# --- M5 LLM ワーカー（Decision / World Event Director） ---
# RC は実 LLM を使う（3.8）。モックのまま RC 判定すると LLM 経路が未検証になる。
LLM_MOCK=0
# Anthropic API キー（MVP-SEC-007: リポジトリへ保存しない）。環境変数 /
# Docker secret から注入する。SDK がこの名前を環境から解決する。
ANTHROPIC_API_KEY=CHANGE_ME_ANTHROPIC_API_KEY
# モデル ID は完全形をそのまま使う（日付サフィックスを付けると 404）。
LLM_MODEL=claude-opus-4-8
# 意思決定は低レイテンシ優先（10.2）。effort 未設定の既定 high は遅いので low から始める。
LLM_EFFORT=low
# 意思決定/提案は小さい構造化出力。大きく取るとコスト暴走（1024 程度）。
LLM_MAX_TOKENS=1024
# クライアント timeout（秒）。既定 10 分は意思決定には長すぎる。超過時は結果を発行しない。
LLM_TIMEOUT_SEC=8
# SDK の自動リトライ回数（429/5xx/接続エラーを指数 Backoff）。自前で再発行しない。
LLM_MAX_RETRIES=3
# Decision の鮮度（秒）。lease_until = created_at + これ。DS の 9.4 鮮度検証で使う。
LLM_DECISION_LEASE_SEC=30
