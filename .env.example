# M0 ローカル開発用環境変数（03B 4章）
# 実値は .env（gitignore）にコピーして使う: cp .env.example .env

# --- Database (PostgreSQL) ---
# サービス→docker network 内では host=postgres。ホスト(WSL2)からは host=localhost。
DATABASE_URL=postgres://survival:survival@postgres:5432/survival?sslmode=disable
# migrate.sh などホストから直接叩く場合に使う（scripts/migrate.sh が参照）
DATABASE_URL_HOST=postgres://survival:survival@localhost:5432/survival?sslmode=disable

POSTGRES_USER=survival
POSTGRES_PASSWORD=survival
POSTGRES_DB=survival

# --- NATS JetStream ---
# コンテナ間は nats、ホストからは localhost
NATS_URL=nats://nats:4222

# --- M7 監視（10B 3.5 / 基本設計第13章） ---
# 全サービスの JSON 構造化ログの閾値: debug|info|warn|error（既定 info）。
# 相関フィールド（world_id/server_id/account_id/actor_id/correlation_id）は
# ログ側が自動で付ける。Password/Token はキー名で機械的に伏せる（MVP-SEC-002）。
# metrics は各サービスの /metrics（Prometheus 形式）で公開する。
LOG_LEVEL=info

# --- サービスポート ---
AUTH_PORT=8081
API_PORT=8082
WORLDSTATE_PORT=8083
LLM_WORKER_PORT=8084

# --- 認証（dev 用のダミー鍵。本番では必ず差し替え） ---
JWT_SIGNING_KEY=dev-only-insecure-signing-key-change-me

# --- M1 Auth / Matchmaking ---
# Access Token = 短寿命 JWT（HS256, 上の JWT_SIGNING_KEY で署名）。
ACCESS_TOKEN_TTL=15m
# Refresh Token = 不透明ランダム（DB はハッシュ保存）。ローテーション寿命。
REFRESH_TOKEN_TTL=720h
# Join Ticket 署名（Ed25519 / EdDSA JWS）。dev 用の決め打ち鍵ペア（04A と一致）。
#   SIGNING_KEY = base64(std) の 32byte seed、PUBLIC_KEY = base64(std) の 32byte 公開鍵。
#   DS(Windows/04A) へ配布するのは PUBLIC_KEY のみ。本番は必ず差し替える。
JOIN_TICKET_SIGNING_KEY=bGl2aW5nLXdvcmxkLXN1cnZpdmFsLWRldi1zZWVkISE=
JOIN_TICKET_PUBLIC_KEY=IRp/SkYEWrMkt5UEtYBoCHgmrd+jbcXACcge3r7eBjo=
JOIN_TICKET_TTL=60s
# 内部 gRPC MatchmakingService の待受ポート（DS⇔Auth 専用）。
AUTH_GRPC_PORT=9091
# 内部 gRPC の共有シークレット（任意。設定時は x-service-secret メタデータ必須）。
# RC では必須にする（.env.rc.example を参照, MVP-SEC-007）。
AUTH_GRPC_SHARED_SECRET=

# --- M7 Rate Limit（第16章 Auth 失敗の Rate Limit / MVP-SEC-005, 10B 3.4） ---
# ログインは **失敗のみ** を数える（成功はトークンを消費しないので、正規利用者は
# 何度ログインしても遮断されない）。キーは送信元 IP。
# 既定 = 1分あたり10回まで失敗可。0 にすると無効化。負値は起動時エラー。
LOGIN_RATE_LIMIT=10
LOGIN_RATE_WINDOW=1m
# 瞬間的に許す最大数（未指定なら LOGIN_RATE_LIMIT と同じ）。
LOGIN_RATE_BURST=10
# アカウント作成は試行そのものを数える（総当り登録の抑止）。
ACCOUNT_CREATE_RATE_LIMIT=5
ACCOUNT_CREATE_RATE_WINDOW=1m

# --- M2 API（WorldData / ActorState 永続化 gRPC） ---
# HTTP(health) は API_PORT=8082、gRPC は別ポート（DS が接続する先, 落とし穴6.10）。
API_GRPC_PORT=8092
# 内部 gRPC の共有シークレット（任意。設定時は x-service-secret メタデータ必須, MVP-SEC-007）。
API_GRPC_SHARED_SECRET=
# Item Definition マスタ（正本 JSON）のパス。コンテナ内は /data 配下想定。
ITEM_DEFINITIONS_PATH=data/item_definitions.json
# Outbox relay のポーリング間隔（≤1s, 3.6）。
OUTBOX_RELAY_INTERVAL=1s
# M7: Outbox depth / event lag の Gauge をサンプリングする間隔（10B 3.5）。
# スクレイプのたびに DB を叩かないよう、タイマーで更新する。
METRICS_SAMPLE_INTERVAL=5s

# --- M6 Economy（EconomyService / 資産ランキング Batch） ---
# EconomyService（CommitPurchase/CommitSale/RegisterBuyer/DespawnBuyer）は上の
# API_GRPC_PORT に相乗りする（M2 の WorldData/ActorState と同一 gRPC サーバ, 09B 3.1）。
# 資産ランキング Batch の実行間隔（既定 1時間・MVP 12.3 / 09B 3.9）。
# 手動実行は内部 HTTP: POST http://api:8082/admin/ranking/run（MVP-SEC-001 内部限定）。
RANKING_BATCH_INTERVAL=1h

# --- M5 LLM ワーカー（Decision / World Event Director） ---
# LLM_MOCK=1 で決定的モック（テスト/オフライン開発・CI 既定）。実 LLM は LLM_MOCK=0。
# 未指定なら ANTHROPIC_API_KEY の有無で判定し、無ければ安全側でモックへフォールバックする。
LLM_MOCK=1
# Anthropic API キー（17章 MVP-SEC-007: リポジトリへ保存しない。.env は gitignore 済み）。
# SDK がこの名前を環境から解決する（M0 の LLM_API_KEY は未使用のため廃止）。
ANTHROPIC_API_KEY=
# モデル ID は完全形をそのまま使う（日付サフィックスを付けると 404）。
LLM_MODEL=claude-opus-4-8
# 意思決定は低レイテンシ優先（10.2）。effort 未設定の既定 high は遅いので low から始める。
LLM_EFFORT=low
# 意思決定/提案は小さい構造化出力。大きく取るとコスト暴走（1024 程度）。
LLM_MAX_TOKENS=1024
# クライアント timeout（秒）。既定 10 分は意思決定には長すぎる。超過時は結果を発行しない。
LLM_TIMEOUT_SEC=8
# SDK の自動リトライ回数（429/5xx/接続エラーを指数 Backoff）。自前で再発行しない。
LLM_MAX_RETRIES=3
# Decision の鮮度（秒）。lease_until = created_at + これ。DS の 9.4 鮮度検証で使う。
LLM_DECISION_LEASE_SEC=30
